  "private": true,
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@testing-library/react": "^16.3.2",
    "apexcharts": "^5.10.4",
    "axios": "^1.15.0",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "date-fns": "^4.1.0",
    "html-webpack-plugin": "^5.6.6",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "react-select": "^5.10.2",
    "style-loader": "^4.0.0",
    "vite": "^8.0.5",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "analyze": "webpack-bundle-analyzer dist/main.js.LICENSE.txt --mode static",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:summary": "vitest run --coverage --reporter=json-summary --reporter=default",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "check": "biome check src/",
    "docs:coverage": "bash scripts/jsdoc-coverage.sh"
  },
  "devServer": {
    "setupMiddlewares": true
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv": "^17.4.0",
    "jsdom": "^29.0.1",
    "vitest": "^4.0.18",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "@noble/hashes": "^2.0.1"
  }
}
